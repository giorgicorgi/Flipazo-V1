# Flipazo — Credenciales (copia este archivo como .env y rellena los valores)

# Telegram: obtén el token en @BotFather y el chat_id en @userinfobot
TELEGRAM_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Amazon Associates España
AMAZON_AFFILIATE_TAG=flipazo-21

# Awin (red de afiliados para PcComponentes, ECI, PSS)
# Publisher ID: aparece en la esquina superior de tu cuenta en https://ui.awin.com
AWIN_PUBLISHER_ID=
MEDIAMARKT_AWIN_MID=6907     # Fallback si Tradedoubler no está configurado
PCCOMPONENTES_AWIN_MID=      # Rellenar tras aprobación del programa en Awin
ELCORTEINGLES_AWIN_MID=      # El Corte Inglés — pendiente aprobación Awin
PRIVATESPORTSHOP_AWIN_MID=   # Private Sport Shop — pendiente aprobación Awin

# Tradedoubler (publisher ID 2468812, site ID 3481714)
# Panel: https://publisher.tradedoubler.com → My Programmes
# IMPORTANTE: TD_PUBLISHER_ID es el SITE ID (3481714) — es el parámetro &a= del deep link
TD_PUBLISHER_ID=3481714
# Token para la Product Feed API (Herramientas → Feeds preconstruidos en el panel TD)
TRADEDOUBLER_TOKEN=
MEDIAMARKT_TD_PID=270504
BEEP_TD_PID=347347
BILLABONG_TD_PID=324694
COLEHAAN_TD_PID=364994
ELEMENT_TD_PID=324735
ELLIOTTI_TD_PID=385916
BEAUTYCORNER_TD_PID=311896
TOYSRUS_TD_PID=211811

# URLs base
REDIRECT_BASE_URL=https://flipazo.es
API_URL=https://api.flipazo.es        # URL pública del backend (para links en emails)

# Analytics — ruta a la BD SQLite compartida (mismo valor en ambos procesos)
DB_PATH=flipazo_deals.db

# Gmail IMAP — para parsear newsletters de Private Sport Shop
# Usa un App Password de Google (no la contraseña normal):
#   https://myaccount.google.com/security → Verificación en 2 pasos → Contraseñas de aplicaciones
EMAIL_ADDRESS=tu@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
PSS_EMAIL_SENDER=newsletter@privatesportshop.es   # Ajustar al remitente real del newsletter

# ── Admin Panel (flipazo.es/elmeromero) ─────────────────────────────────────
# ADMIN_USERNAME: nombre de usuario para acceder al panel de admin
# ADMIN_PASSWORD: contraseña en texto plano (almacenada solo en .env del servidor, nunca en git)
# JWT_SECRET: cadena aleatoria para firmar tokens JWT. Genera una con: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu_contraseña_segura_aqui
JWT_SECRET=genera_una_cadena_aleatoria_de_64_caracteres_aqui

# ── Google OAuth (flipazo.es/cuenta) ────────────────────────────────────────
# 1. Ve a https://console.cloud.google.com → APIs & Services → Credentials
# 2. Crea un OAuth 2.0 Client ID (tipo: Web application)
# 3. Añade en "Authorized redirect URIs": https://api.flipazo.es/auth/google/callback
# 4. Copia el Client ID y Client Secret aquí
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_REDIRECT_URI=https://api.flipazo.es/auth/google/callback

# ── Apple Sign In (flipazo.es/cuenta) ───────────────────────────────────────
# 1. Ve a https://developer.apple.com → Certificates, Identifiers & Profiles
# 2. Crea un Service ID (Identifiers → +) con dominio flipazo.es y return URL https://api.flipazo.es/auth/apple/callback
# 3. En el Service ID, activa "Sign In with Apple" y configura el dominio
# APPLE_CLIENT_ID es el bundle ID del Service ID (ej: es.flipazo.signin)
APPLE_CLIENT_ID=es.flipazo.signin
APPLE_REDIRECT_URI=https://api.flipazo.es/auth/apple/callback

# URL de la página de cuenta (a donde redirige el backend tras OAuth)
FRONTEND_CUENTA=https://flipazo.es/cuenta

